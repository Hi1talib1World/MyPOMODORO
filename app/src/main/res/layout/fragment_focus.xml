<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/focus_scroll_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/brand_blue">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/focus_layout_inner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="120dp">

        <!-- Mode Toggle -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:layout_marginHorizontal="24dp"
            app:checkedButton="@+id/btn_focus"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_focus"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Focus"
                app:backgroundTint="@color/brand_yellow"
                android:textColor="@color/brand_blue" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_short_break"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Short Break"
                android:textSize="12sp"
                android:textColor="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_long_break"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Long Break"
                android:textSize="12sp"
                android:textColor="@color/white" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Timer Progress Circle -->
        <FrameLayout
            android:id="@+id/timer_container"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_marginTop="64dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/toggleGroup">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressBarCircle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                app:indicatorSize="280dp"
                app:trackThickness="12dp"
                app:indicatorColor="@color/brand_yellow"
                app:trackColor="@color/brand_blue_card"
                app:trackCornerRadius="10dp"
                android:max="1000"
                android:progress="1000" />

            <TextView
                android:id="@+id/textViewTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="25:00"
                android:textColor="@color/brand_yellow"
                android:textSize="72sp"
                android:fontFamily="sans-serif-light" />
        </FrameLayout>

        <!-- Stats Summary -->
        <LinearLayout
            android:id="@+id/stats_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/timer_container">

            <TextView
                android:id="@+id/today_pomos_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/brand_yellow"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Sessions Today"
                android:textColor="@color/brand_grey"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Start Session Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/imageViewStartStop"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="24dp"
            android:text="START SESSION"
            android:textSize="18sp"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/brand_yellow"
            android:textColor="@color/brand_blue"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/stats_summary" />

        <!-- Reset Timer -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/Reset"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Reset Timer"
            android:textColor="@color/white"
            app:icon="@drawable/icon_reset"
            app:iconTint="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageViewStartStop" />

        <!-- Finish Message -->
        <TextView
            android:id="@+id/finishMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Session Finished!"
            android:textColor="@color/brand_yellow"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/Reset" />

        <!-- Active Task Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/task_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/brand_blue_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/finishMessage">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/active_task_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVE TASK"
                    android:textColor="@color/brand_grey"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/edit_task"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/edit_icon"
                    app:tint="@color/brand_grey"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:contentDescription="Edit task" />

                <RadioButton
                    android:id="@+id/task_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:buttonTint="@color/brand_yellow"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/active_task_label" />

                <TextView
                    android:id="@+id/activity_label_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Focus Activity"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/task_checkbox"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/task_checkbox"
                    app:layout_constraintTop_toTopOf="@id/task_checkbox" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_type"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginTop="16dp"
                    android:text="Deep Work"
                    app:chipBackgroundColor="@color/brand_blue"
                    app:chipStrokeWidth="0dp"
                    android:textColor="@color/brand_grey"
                    android:textSize="11sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/activity_label_button" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_project"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:text="General"
                    app:chipBackgroundColor="@color/brand_blue"
                    app:chipStrokeWidth="0dp"
                    android:textColor="@color/brand_grey"
                    android:textSize="11sp"
                    app:layout_constraintBottom_toBottomOf="@id/chip_type"
                    app:layout_constraintStart_toEndOf="@id/chip_type"
                    app:layout_constraintTop_toTopOf="@id/chip_type" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
