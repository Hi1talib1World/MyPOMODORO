<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/rounded_rectangle"
    android:backgroundTint="#24395B"
    android:padding="12dp">

    <ImageView
        android:id="@+id/widget_logo"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/logo"
        android:alpha="0.8"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true" />

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FOCUS"
        android:textColor="#A0B0D0"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_toEndOf="@id/widget_logo"
        android:layout_marginStart="8dp"
        android:layout_alignTop="@id/widget_logo" />

    <TextView
        android:id="@+id/widget_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="25:00"
        android:textColor="#FDFE97"
        android:textSize="32sp"
        android:fontFamily="sans-serif-light"
        android:layout_centerInParent="true" />

    <LinearLayout
        android:id="@+id/widget_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_play_pause"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_play_button"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

        <ImageView
            android:id="@+id/widget_reset"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/icon_reset"
            android:layout_marginStart="16dp"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

</RelativeLayout>
