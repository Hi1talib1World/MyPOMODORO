<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#24395B">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                app:cardBackgroundColor="#3A4D6E"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/logo"
                        android:alpha="0.05"
                        android:contentDescription="Settings Header Background" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_marginStart="24dp"
                        android:layout_marginBottom="24dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PREFERENCES"
                            android:textColor="#A0B0D0"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Settings"
                            android:textColor="#FDFE97"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:letterSpacing="0.1"
                android:text="TIMER DURATIONS"
                android:textColor="#A0B0D0"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Focus Duration Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#3A4D6E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#50668F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/icon_focus"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_focus"
                            android:contentDescription="Focus Icon"
                            app:tint="#FDFE97" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/icon_focus"
                            android:text="Focus"
                            android:textColor="@color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/focus_duration_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/rounded_rectangle"
                            android:backgroundTint="#24395B"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="25m"
                            android:textColor="#FDFE97"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/focus_slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:valueFrom="1"
                        android:valueTo="60"
                        android:stepSize="1"
                        app:thumbColor="#FDFE97"
                        app:trackColorActive="#FDFE97"
                        app:trackColorInactive="#24395B" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Short Break Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#3A4D6E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#50668F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/icon_short"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_break"
                            android:contentDescription="Short Break Icon"
                            app:tint="#FDFE97" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/icon_short"
                            android:text="Short Break"
                            android:textColor="@color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/short_break_duration_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/rounded_rectangle"
                            android:backgroundTint="#24395B"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="5m"
                            android:textColor="#FDFE97"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/short_break_slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:valueFrom="1"
                        android:valueTo="30"
                        android:stepSize="1"
                        app:thumbColor="#FDFE97"
                        app:trackColorActive="#FDFE97"
                        app:trackColorInactive="#24395B" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Long Break Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#3A4D6E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#50668F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/icon_long"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_moon"
                            android:contentDescription="Long Break Icon"
                            app:tint="#FDFE97" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/icon_long"
                            android:text="Long Break"
                            android:textColor="@color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/long_break_duration_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/rounded_rectangle"
                            android:backgroundTint="#24395B"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="15m"
                            android:textColor="#FDFE97"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/long_break_slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:valueFrom="1"
                        android:valueTo="60"
                        android:stepSize="1"
                        app:thumbColor="#FDFE97"
                        app:trackColorActive="#FDFE97"
                        app:trackColorInactive="#24395B" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:letterSpacing="0.1"
                android:text="PREFERENCES"
                android:textColor="#A0B0D0"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Switches Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#3A4D6E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#50668F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Auto-start Breaks -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:paddingHorizontal="12dp">

                        <ImageView
                            android:id="@+id/icon_auto"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_play_button"
                            android:contentDescription="Auto-start Icon"
                            app:tint="#A0B0D0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/icon_auto"
                            android:text="Auto-start Breaks"
                            android:textColor="@color/white" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/auto_start_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="#FDFE97"
                            app:trackTint="#24395B" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="#24395B" />

                    <!-- Notification Sounds -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:paddingHorizontal="12dp">

                        <ImageView
                            android:id="@+id/icon_bell"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_notifications"
                            android:contentDescription="Notification Icon"
                            app:tint="#A0B0D0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/icon_bell"
                            android:text="Notification Sounds"
                            android:textColor="@color/white" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/notification_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="#FDFE97"
                            app:trackTint="#24395B" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="#24395B" />

                    <!-- Dark Mode -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:paddingHorizontal="12dp">

                        <ImageView
                            android:id="@+id/icon_dark"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_moon"
                            android:contentDescription="Dark Mode Icon"
                            app:tint="#A0B0D0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/icon_dark"
                            android:text="Dark Mode"
                            android:textColor="@color/white" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/dark_mode_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="#FDFE97"
                            app:trackTint="#24395B" />
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:letterSpacing="0.1"
                android:text="ABOUT"
                android:textColor="#A0B0D0"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- About Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#3A4D6E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#50668F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:paddingHorizontal="12dp">

                        <ImageView
                            android:id="@+id/icon_info"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_info"
                            android:contentDescription="Version Icon"
                            app:tint="#A0B0D0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/icon_info"
                            android:text="Version"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/version_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="1.0.3"
                            android:textColor="#A0B0D0" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="#24395B" />

                    <RelativeLayout
                        android:id="@+id/privacy_policy_row"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="12dp">

                        <ImageView
                            android:id="@+id/icon_privacy"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_shield"
                            android:contentDescription="Privacy Icon"
                            app:tint="#A0B0D0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/icon_privacy"
                            android:text="Privacy Policy"
                            android:textColor="@color/white" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_baseline_add_24"
                            android:rotation="45"
                            android:contentDescription="Arrow Icon"
                            app:tint="#A0B0D0" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reset Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_all"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:text="Reset All Settings"
                android:textColor="#FDFE97"
                app:backgroundTint="#DA1E5B"
                app:cornerRadius="16dp"
                app:icon="@drawable/trash_icon"
                app:iconTint="#FDFE97" />

            <View android:layout_width="match_parent" android:layout_height="100dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
